%%{init: {'theme': 'base', 'themeVariables': { 'lineColor': '#9e9e9e' }}}%%
flowchart LR
%% Native Mermaid Styling (No HTML) - Node Classes
classDef obsNode fill:#81d4fa,stroke:#01579b,stroke-width:2px,color:#000000;
classDef proxyNode fill:#ffe0b2,stroke:#ef6c00,stroke-width:2px,color:#000000;
classDef collectNode fill:#e1bee7,stroke:#6a1b9a,stroke-width:2px,color:#000000;
classDef hostNode fill:#b3e5fc,stroke:#0277bd,stroke-width:2px,color:#000000;

%% Core Component
alloy[alloy]:::collectNode

%% Grouped Components
subgraph Host [Host System Sources]
journald[Host FS / var/log/journal]:::hostNode
podman_socket[Host OS / Podman Socket]:::hostNode
end

subgraph Ingress [Ingress / Proxy]
traefik[traefik]:::proxyNode
end

subgraph Observability [Observability Backend]
loki[loki]:::obsNode
pyroscope[pyroscope]:::obsNode
end

subgraph Monitoring [Monitoring & Probes]
prometheus[prometheus]:::obsNode
blackbox_exporter[blackbox-exporter]:::collectNode
end

%% Data Collection (Inputs)
podman_socket -.->|Socket/TCP Read Container Logs| alloy
journald -.->|Host FS Read System Logs| alloy
prometheus -.->|Port 9090/HTTP Pull pprof Profiles| alloy

%% Data Export (Outputs)
alloy -->|Port 3100/HTTP Push Logs| loki
alloy -->|Port 4040/HTTP Push Profiles| pyroscope

%% Ingress Routing
traefik -->|Port 12345/HTTP Route| alloy

%% Metrics Scraping & Probes
prometheus -->|Port 12345/HTTP Scrape Metrics| alloy
blackbox_exporter -.->|Port 12345/HTTP Health Probe| alloy

%% Subgraph Styling (Background blocks)
style Host fill:#f5f5f5,stroke:#cfd8dc,stroke-width:2px,rx:10,ry:10
style Ingress fill:#fff8e1,stroke:#ffe082,stroke-width:2px,rx:10,ry:10
style Observability fill:#e0f7fa,stroke:#80deea,stroke-width:2px,rx:10,ry:10
style Monitoring fill:#eceff1,stroke:#b0bec5,stroke-width:2px,rx:10,ry:10